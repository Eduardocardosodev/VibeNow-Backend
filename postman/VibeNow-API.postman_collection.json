          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"establishmentId\": 1,\n  \"name\": \"Noite do Samba\",\n  \"description\": \"Especial de verão\",\n  \"attractions\": \"Banda XYZ\\nShow de luzes\",\n  \"dj\": \"DJ Silva\",\n  \"priceInfo\": \"Entrada R$ 40 | VIP R$ 120 | Mesa 6 pessoas R$ 600\",\n  \"eventStartsAt\": \"2026-04-15T22:00:00.000Z\",\n  \"eventEndsAt\": \"2026-04-16T04:00:00.000Z\",\n  \"listType\": \"FRIEND_LIST\",\n  \"posterImageUrl\": \"https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=600\",\n  \"offersTableReservation\": true,\n  \"tablePeopleCapacity\": 6,\n  \"tablesAvailable\": 12,\n  \"offersBoothReservation\": true,\n  \"boothPeopleCapacity\": 10,\n  \"boothsAvailable\": 4,\n  \"tablePrice\": 134.23,\n  \"boothPrice\": 899.99\n}"
            },
            "url": "{{baseUrl}}/events-schedule",
            "description": "Reservas: mesa exige tablePeopleCapacity, tablesAvailable, tablePrice (decimal); camarote exige boothPeopleCapacity, boothsAvailable, boothPrice. Preços 0.01–999999.99."
          }
        },

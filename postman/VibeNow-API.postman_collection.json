{
  "info": {
    "name": "VibeNow API",
    "description": "Auth (login + refresh), Users, Establishments, Feedbacks, Menu, Quotes e Events Schedule.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3004" },
    { "key": "token", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "menuId", "value": "1" },
    { "key": "menuItemId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) {",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "  }",
                  "  if (json.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+5511999999999\",\n  \"password\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Público. Retorna accessToken, refreshToken, expiresIn, tokenType. Salva token e refreshToken nas variáveis da collection."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) {",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "  }",
                  "  if (json.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Público. Body com refreshToken (use a variável {{refreshToken}} após o Login). Devolve novo par access + refresh."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"phone\": \"+5511988887777\",\n  \"password\": \"12345678\",\n  \"email\": \"joao@email.com\"\n}"
            },
            "url": "{{baseUrl}}/users",
            "description": "Rota pública."
          }
        },
        {
          "name": "Get Me (perfil)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/users/me",
            "description": "Usuário logado (Bearer access token)."
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/users",
            "description": "Requer autenticação."
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/users/1",
            "description": "Requer autenticação."
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva Atualizado\"\n}"
            },
            "url": "{{baseUrl}}/users/1",
            "description": "Requer autenticação."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/users/1",
            "description": "Requer autenticação."
          }
        }
      ]
    },
    {
      "name": "Establishments",
      "item": [
        {
          "name": "Create Establishment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lounge Exemplo\",\n  \"cnpj\": \"12345678000199\",\n  \"address\": \"Rua Exemplo, 100\",\n  \"city\": \"Canoas\",\n  \"state\": \"RS\",\n  \"zipCode\": \"92020000\",\n  \"phone\": \"+551133334444\",\n  \"email\": \"contato@lounge.com\",\n  \"instagram\": \"@loungeexemplo\",\n  \"establishmentType\": \"LOUNGE\",\n  \"latitude\": -29.9178,\n  \"longitude\": -51.1836,\n  \"openingHours\": {\n    \"friday\": { \"open\": \"19:00\", \"close\": \"02:00\" },\n    \"saturday\": { \"open\": \"19:00\", \"close\": \"02:00\" },\n    \"sunday\": null\n  }\n}"
            },
            "url": "{{baseUrl}}/establishments",
            "description": "establishmentType: LOUNGE ou PARTY. openingHours opcional (chaves monday..sunday)."
          }
        },
        {
          "name": "List Establishments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/establishments",
            "description": "Requer autenticação."
          }
        },
        {
          "name": "List Near (mapa)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/establishments/near?lat=-29.9178&lng=-51.1836&radiusKm=10",
              "host": ["{{baseUrl}}"],
              "path": ["establishments", "near"],
              "query": [
                { "key": "lat", "value": "-29.9178" },
                { "key": "lng", "value": "-51.1836" },
                { "key": "radiusKm", "value": "10" }
              ]
            },
            "description": "Estabelecimentos próximos. radiusKm opcional (default 10)."
          }
        },
        {
          "name": "Map bounds (área visível)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/establishments/map-bounds?swLat=-29.95&swLng=-51.22&neLat=-29.88&neLng=-51.15&centerLat=-29.9178&centerLng=-51.1836&limit=120",
              "host": ["{{baseUrl}}"],
              "path": ["establishments", "map-bounds"],
              "query": [
                { "key": "swLat", "value": "-29.95" },
                { "key": "swLng", "value": "-51.22" },
                { "key": "neLat", "value": "-29.88" },
                { "key": "neLng", "value": "-51.15" },
                { "key": "centerLat", "value": "-29.9178" },
                { "key": "centerLng", "value": "-51.1836" },
                { "key": "limit", "value": "120" }
              ]
            },
            "description": "Só pins dentro do retângulo (mapa). centerLat/Lng opcionais: ordena por distância e retorna distanceKm. limit 1–250 (default 120). Zoom muito aberto: máx. 8° de largura/altura."
          }
        },
        {
          "name": "Get Establishment by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/establishments/1",
            "description": "Requer autenticação."
          }
        },
        {
          "name": "Update Establishment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lounge Exemplo Atualizado\"\n}"
            },
            "url": "{{baseUrl}}/establishments/1",
            "description": "Requer autenticação."
          }
        },
        {
          "name": "Delete Establishment",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/establishments/1",
            "description": "Requer autenticação."
          }
        }
      ]
    },

          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/events-schedule/1",
            "description": "Remove evento."
          }
        }
      ]
    }
  ]
}

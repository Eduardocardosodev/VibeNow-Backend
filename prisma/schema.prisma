generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstablishmentType {
  LOUNGE
  PARTY
}

/** Tipo de lista / entrada do evento */
enum EventListType {
  GENERAL      // entrada normal
  FREE_LIST    // lista free
  FRIEND_LIST  // lista amiga
  VIP
}

enum UserRole {
  NORMAL_USER 
  ADMIN
  OWNER_ESTABLISHMENT
  EMPLOYEE_ESTABLISHMENT 
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?   @unique
  phone     String    @unique
  password  String
  role      UserRole  @default(NORMAL_USER)

  dateOfBirth            DateTime? @map("date_of_birth") @db.Date
  acceptedTermsOfUse     Boolean   @default(false) @map("accepted_terms_of_use")
  acceptedPrivacyPolicy  Boolean   @default(false) @map("accepted_privacy_policy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  feedbacks                Feedback[]
  eventRegistrations       EventRegistration[]
  ownedEstablishments      Establishment[]           @relation("EstablishmentOwner")
  establishmentEmployments EstablishmentEmployee[]
  customerOrders           CustomerOrder[]

  @@map("users")
}

model Establishment {
  id        Int      @id @default(autoincrement())
  name      String
  cnpj      String   @unique
  address   String
  /** Número (logradouro), ex.: "1200", "42A", "S/N". */
  addressNumber String @map("address_number") @db.VarChar(30)
  city      String
  state     String
  zipCode   String
  phone     String
  email     String   @unique
  instagram String   @unique
  establishmentType EstablishmentType
  profilePhoto String?
  latitude      Float
  longitude     Float
  score         Float
  openingHours  Json?   // horário por dia: { "monday": { "open": "18:00", "close": "02:00" }, "sunday": null }
  /** IANA (ex.: America/Sao_Paulo) — horário de funcionamento e períodos de score por “dia operacional”. */
  operatingTimeZone String @default("America/Sao_Paulo") @map("operating_time_zone") @db.VarChar(64)
  /** Dono do portal (1 login por estabelecimento). */
  ownerUserId   Int?    @map("owner_user_id")
  /** Se true, após POST /feedbacks o app pode mostrar `reward.message` ao utilizador. */
  feedbackRewardEnabled Boolean @default(false) @map("feedback_reward_enabled")
  /** Texto livre (desconto, bebida, etc.); se vazio com recompensa ligada, o backend usa mensagem padrão. */
  feedbackRewardMessage String? @db.VarChar(500) @map("feedback_reward_message")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner           User?                   @relation("EstablishmentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  feedbacks       Feedback[]
  operatingSession EstablishmentOperatingSession?
  scorePeriods    EstablishmentScorePeriod[]
  menu            Menu?
  quotes          Quote[]
  scheduledEvents ScheduledEvent[]
  employees       EstablishmentEmployee[]
  customerOrders  CustomerOrder[]

  @@index([ownerUserId])
  @@index([latitude, longitude])
  @@map("establishments")
}

/** Sessão operacional corrente: agregados de feedback até periodEndUtc (média exposta em establishments.score). */
model EstablishmentOperatingSession {
  establishmentId Int      @id @map("establishment_id")
  periodStartUtc    DateTime @map("period_start_utc")
  periodEndUtc      DateTime @map("period_end_utc")
  sumRating         Float    @default(0) @map("sum_rating")
  feedbackCount     Int      @default(0) @map("feedback_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@index([periodEndUtc])
  @@map("establishment_operating_sessions")
}

/** Histórico de períodos fechados (média materializada ao fim do dia operacional). */
model EstablishmentScorePeriod {
  id              Int      @id @default(autoincrement())
  establishmentId Int    @map("establishment_id")
  periodStartUtc  DateTime @map("period_start_utc")
  periodEndUtc    DateTime @map("period_end_utc")
  sumRating       Float    @map("sum_rating")
  feedbackCount   Int      @map("feedback_count")
  averageRating   Float    @map("average_rating")
  closedAt        DateTime @default(now()) @map("closed_at")

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@index([establishmentId, periodEndUtc])
  @@map("establishment_score_periods")
}

/** Funcionário vinculado a um estabelecimento (app mobile, permissões restritas). */
model EstablishmentEmployee {
  id              Int      @id @default(autoincrement())
  establishmentId Int
  userId          Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([establishmentId, userId])
  @@map("establishment_employees")
}

model ScheduledEvent {
  id              Int      @id @default(autoincrement())
  establishmentId Int
  name            String   @db.VarChar(160)
  description     String?  @db.VarChar(2000)
  attractions     String?  @db.VarChar(2000) // atrações (texto; pode usar linhas)
  dj              String?  @db.VarChar(160)
  priceInfo       String?  @db.VarChar(500) // preços em texto livre (ex.: "Entrada R$ 30 | VIP R$ 100")
  eventStartsAt   DateTime // início do evento (data + hora)
  eventEndsAt     DateTime? // fim opcional
  listType        EventListType @default(GENERAL)
  posterImageUrl  String?  @db.VarChar(500)
  /** Reserva de mesa: disponível no evento e capacidade (pessoas por mesa). */
  offersTableReservation Boolean  @default(false)
  tablePeopleCapacity    Int?
  /** Quantidade de mesas disponíveis para reserva neste evento. */
  tablesAvailable        Int?
  /** Valor da reserva de mesa (por mesa), ex.: 134.23 */
  tablePrice             Decimal? @db.Decimal(10, 2)
  /** Reserva de camarote: disponível e capacidade (pessoas por camarote). */
  offersBoothReservation Boolean  @default(false)
  boothPeopleCapacity    Int?
  /** Quantidade de camarotes disponíveis para reserva neste evento. */
  boothsAvailable        Int?
  /** Valor da reserva de camarote (por camarote), ex.: 134.23 */
  boothPrice             Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment   Establishment        @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  registrations   EventRegistration[]

  @@index([establishmentId, eventStartsAt])
  @@map("scheduled_events")
}

/** Inscrição do usuário em um evento agendado (uma por usuário/evento). */
model EventRegistration {
  id                Int      @id @default(autoincrement())
  userId            Int
  scheduledEventId  Int
  createdAt         DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledEvent ScheduledEvent @relation(fields: [scheduledEventId], references: [id], onDelete: Cascade)

  @@unique([userId, scheduledEventId])
  @@index([scheduledEventId])
  @@map("event_registrations")
}

model Quote {
  id              Int      @id @default(autoincrement())
  establishmentId Int
  text            String   @db.VarChar(80) // frase de até 80 caracteres, visível por 12h
  expiresAt       DateTime // createdAt + 12h
  createdAt       DateTime @default(now())

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@map("quotes")
}

enum MenuItemType {
  ALCOHOLIC_DRINK    // bebidas alcoólicas
  NON_ALCOHOLIC_DRINK // bebidas sem álcool
  COMBO
  BOTTLE             // garrafas
  FOOD               // comidas
  HOOKAH             // narguile
}

model Menu {
  id              Int   @id @default(autoincrement())
  establishmentId Int   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  items         MenuItem[]

  @@map("menus")
}

model MenuItem {
  id             Int      @id @default(autoincrement())
  menuId         Int
  name           String
  description    String?
  photoMenuItem  String?  // URL da foto do item (drink, etc.)
  price          Decimal  @db.Decimal(10, 2)
  type           MenuItemType
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("menu_items")
}

/** Pedido no app (cardápio + onde o cliente está). */
enum OrderStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

model CustomerOrder {
  id              Int         @id @default(autoincrement())
  establishmentId Int
  userId          Int
  /** Onde encontrar o cliente: mesa, camarote, área, etc. */
  locationNote    String      @db.VarChar(500)
  status          OrderStatus @default(PENDING)
  /** Dedup de retries (mesmo user + mesma chave = mesmo pedido). */
  idempotencyKey  String?     @map("idempotency_key") @db.VarChar(128)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@unique([userId, idempotencyKey], map: "customer_orders_user_id_idempotency_key_key")
  @@index([establishmentId, status, createdAt])
  @@map("customer_orders")
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  menuItemId Int?
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  itemName   String   @db.VarChar(160)
  createdAt  DateTime @default(now())

  order    CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem?     @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model Feedback {
  id                  Int       @id @default(autoincrement())
  userId              Int
  establishmentId     Int
  rating              Float     // média calculada dos 5 tópicos
  ratingCrowding      Int       // Lotação (1-5)
  ratingAnimation     Int       // Animação (1-5)
  ratingOrganization  Int       // Organização (1-5)
  ratingHygiene       Int       // Higiene (1-5)
  ratingAmbience      Int       // Clima/Pessoas (1-5)
  comment             String?
  photoUrl            String?
  /** Chave do cliente para deduplicar retries (mesmo user + mesma key = mesmo registro). Opcional até app mandar header. */
  idempotencyKey      String?   @map("idempotency_key") @db.VarChar(128)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey], map: "feedbacks_user_id_idempotency_key_key")
  @@map("feedbacks")
}

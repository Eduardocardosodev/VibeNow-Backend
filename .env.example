# =============================================================================
# VibeNow Backend — copie para .env e preencha os valores
# =============================================================================

# PostgreSQL (Prisma)
# Ex.: postgresql://USER:PASSWORD@localhost:5432/vibenow?schema=public
DATABASE_URL=

# Porta HTTP do NestJS (default 3004 se omitido)
PORT=3004

# -----------------------------------------------------------------------------
# JWT — access token (rotas protegidas / AuthGuard)
# -----------------------------------------------------------------------------
# Chave secreta forte (ex.: openssl rand -base64 64)
SECRET_KEY=

# Expiração padrão do módulo JWT em segundos (ex.: 3600 = 1h)
# Observação: o login também usa JWT_ACCESS_EXPIRES no AuthUsecase quando definido
EXPIRES_IN=3600

# Duração do access token no login (formato string: 15m, 1h, 7d)
JWT_ACCESS_EXPIRES=15m

# -----------------------------------------------------------------------------
# JWT — refresh token (stateless, assinatura separada)
# -----------------------------------------------------------------------------
# Obrigatório em produção. Deve ser diferente de SECRET_KEY (ex.: openssl rand -base64 64)
JWT_REFRESH_SECRET=

# Duração do refresh token (ex.: 7d, 30d)
JWT_REFRESH_EXPIRES=7d
